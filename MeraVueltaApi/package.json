{
  "name": "prizma-talaria-backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "dev": "ts-node-dev --respawn -- src/index.ts",
    "test": "jest",
    "coverage": "jest --coverage",
    "typeorm": "ts-node -r ts-node/register ./node_modules/.bin/typeorm --config ./src/ormconfig.ts",
    "migration:create": "npm run typeorm migration:create -- -n",
    "migration:generate": "npm run typeorm migration:generate -- -n",
    "migration:run": "npm run typeorm migration:run",
    "migration:revert": "npm run typeorm migration:revert",
    "migration:show": "npm run typeorm migration:show",
    "schema:sync": "npm run typeorm schema:sync",
    "schema:log": "npm run typeorm schema:log",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --fix --ext .js,.ts",
    "create-doc": "npm run build && npx jsdoc dist/modules/* -d docs/",
    "tsdocs": "npx typedoc --out ./docs/ ./src"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stevenvo780/ApiDomiciliosTypeScript.git"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hapi/boom": "9.1.0",
    "@hapi/hapi": "^19.0.0",
    "@hapi/inert": "^6.0.3",
    "@hapi/joi": "^17.1.1",
    "@hapi/vision": "^6.0.1",
    "axios": "^0.21.4",
    "bcrypt": "^5.0.1",
    "class-transformer": "^0.5.1",
    "dotenv": "^8.2.0",
    "firebase-admin": "^11.0.1",
    "glob": "^7.1.6",
    "google-spreadsheet": "^3.3.0",
    "hapi-auth-jwt2": "8.6.0",
    "jsonwebtoken": "^8.5.1",
    "luxon": "^1.26.0",
    "md5": "^2.3.0",
    "mercadopago": "^2.13.0",
    "moment-timezone": "^0.5.33",
    "node-mailjet": "^3.4.1",
    "prizma-contracts": "^1.3.0",
    "prizma-payments": "^1.0.1",
    "papaparse": "^5.3.1",
    "pg": "^8.7.1",
    "ts-node": "^10.9.1",
    "twilio": "^3.73.0",
    "typeorm": "^0.2.29",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@types/glob": "^7.2.0",
    "@types/jest": "^26.0.19",
    "@types/luxon": "^1.26.5",
    "@types/minimatch": "^3.0.5",
    "@types/node": "^14.14.19",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^4.12.0",
    "@typescript-eslint/parser": "^4.12.0",
    "eslint": "^7.17.0",
    "eslint-config-prettier": "^7.1.0",
    "eslint-plugin-jest": "^24.1.3",
    "husky": "^4.3.6",
    "jest": "^26.6.3",
    "jest-tap-reporter": "^1.9.0",
    "supertest": "^6.3.4",
    "ts-jest": "^26.4.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.5.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "modulePathIgnorePatterns": [
      "npm-cache",
      ".npm"
    ],
    "reporters": [
      "jest-tap-reporter"
    ]
  },
  "directories": {
    "test": "test"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run build && npm run lint:fix && npm test"
    }
  }
}
